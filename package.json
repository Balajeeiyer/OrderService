{
  "name": "order-service",
  "version": "1.0.0",
  "description": "Order Management Service - Consumes MockAI Products API",
  "main": "index.js",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build",
    "deploy": "cds deploy",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest test/integration/mockai-integration.test.js",
    "test:schema": "jest test/integration/schema-validator.test.js",
    "test:performance": "node test/integration/performance-benchmark.js"
  },
  "keywords": [
    "SAP",
    "CAP",
    "CDS",
    "orders",
    "microservices"
  ],
  "author": "Balajeeiyer",
  "license": "ISC",
  "dependencies": {
    "@sap/cds": "^7.5.0",
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "opossum": "^8.1.0",
    "async-retry": "^1.3.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "autocannon": "^7.12.0",
    "xml2js": "^0.6.2",
    "sqlite3": "^5.1.6"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
